meta {
  name: Update Profile
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/users/profile
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
      "full_name": "Updated Name",
      "phone": "0987654321",
      "education_level": "Bachelor's Degree",
      "current_status": "student",
      "interests": "programming, design"
  }
}

settings {
  encodeUrl: true
}
