meta {
  name: Submit Assessment
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/assessment/submit
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
      "answers": [
          {
              "question_id": 1,
              "answer": "strongly_agree"
          },
          {
              "question_id": 2,
              "answer": "agree"
          }
      ]
  }
}

settings {
  encodeUrl: true
}
