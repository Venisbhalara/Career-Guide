meta {
  name: Book Session
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/counselling/book
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
      "session_date": "2024-03-20",
      "session_time": "10:00",
      "counsellor_name": "Dr. Smith",
      "notes": "Reason for booking"
  }
}

settings {
  encodeUrl: true
}
